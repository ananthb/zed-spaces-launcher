{
  // Default target to use when no target name is given.
  "defaultTarget": "demo",

  // Applet settings (menu bar icon, hotkey, codespace lifecycle).
  "daemon": {
    "hotkey": "Cmd+Shift+S",
    // What the hotkey does: "picker" (default), "previous", or "default"
    "hotkeyAction": "picker",
    "terminal": "auto",
    "pollInterval": "5m",
    // Hold a sleep inhibitor while a launched SSH session is alive.
    // "off" (default), "sleep", or "sleep+shutdown" (Linux only; macOS
    // treats sleep+shutdown as sleep).
    "inhibitSleep": "off"
  },

  "targets": {
    "demo": {
      "repository": "owner/repository",
      "branch": "main",
      "displayName": "repository-main",
      "workspacePath": "/workspaces/repository",

      // gh codespace create options
      "machine": "standardLinux32gb",
      "location": "EastUs",
      "devcontainerPath": ".devcontainer/devcontainer.json",
      "idleTimeout": "30m",
      "retentionPeriod": "72h",

      // Zed display options
      "uploadBinaryOverSsh": true,
      "zedNickname": "repository-main",

      // Lifecycle (used by applet)
      "autoStop": "30m",
      "preWarm": "08:00"
    }
  }
}
