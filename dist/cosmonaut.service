[Unit]
Description=cosmonaut menu bar applet
Documentation=https://github.com/linuskendall/cosmonaut
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/cosmonaut applet
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
